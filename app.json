{
  "expo": {
    "name": "ECOMTICKET",
    "slug": "ecom-ticket",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/bg launch screen.png",
      "resizeMode": "cover",
      "backgroundColor": "#000000"
    },
    "icon": "./assets/bg enter screen.png",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/bg enter screen.png",
        "backgroundColor": "#E50914"
      },
      "package": "com.example.ecomticket"
    },
    "ios": {
      "bundleIdentifier": "com.example.ecomticket"
    },
    "web": {
      "bundler": "metro"
    }
  }
}

